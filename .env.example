# ─── Gemini AI ────────────────────────────────────────────────────────────────
# VITE_ prefix = accessible in the browser (frontend)
VITE_GEMINI_API_KEY=

# No VITE_ prefix = server-side only (server.ts)
# IMPORTANT: Both are needed. GEMINI_API_KEY is the fix for the broken AI brief endpoint.
GEMINI_API_KEY=

# ─── Supabase ─────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Server-side admin key (never expose to frontend)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── Stripe ───────────────────────────────────────────────────────────────────
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Create these in Stripe Dashboard → Products
# $29/mo "LATAM INTEL Executive" recurring price
VITE_STRIPE_PRO_PRICE_ID=price_...

# ─── Coinbase Commerce (crypto payments) ──────────────────────────────────────
COINBASE_COMMERCE_API_KEY=
COINBASE_COMMERCE_WEBHOOK_SECRET=

# ─── Beehiiv Newsletter ───────────────────────────────────────────────────────
# Get from app.beehiiv.com → Settings → API
BEEHIIV_API_KEY=
BEEHIIV_PUB_ID=pub_...

# ─── Resend Email ─────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...

# ─── News APIs ────────────────────────────────────────────────────────────────
# Primary news source (newsdata.io — free tier: 200 req/day)
NEWSDATA_API_KEY=

# Secondary / market intel
NEWS_API_KEY=

# ─── Job APIs ─────────────────────────────────────────────────────────────────
RAPIDAPI_TECHMAP_KEY=
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
RAPIDAPI_LINKEDIN_KEY=

# ─── TheirStack (hiring trends) ───────────────────────────────────────────────
THEIRSTACK_API_KEY=

# ─── Cron protection ──────────────────────────────────────────────────────────
# Add this to GitHub Actions / Railway cron as x-cron-secret header
# Generate with: openssl rand -hex 32
CRON_SECRET=

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
