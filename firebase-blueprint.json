{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user information and subscription status",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email", "description": "User's email" },
        "displayName": { "type": "string", "description": "User's display name" },
        "photoURL": { "type": "string", "description": "User's photo URL" },
        "subscriptionStatus": { "type": "string", "enum": ["free", "premium", "admin"], "description": "Current subscription tier" },
        "stripeCustomerId": { "type": "string", "description": "Stripe Customer ID" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation date" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Last update timestamp" }
      },
      "required": ["uid", "email", "subscriptionStatus", "createdAt", "updatedAt"]
    },
    "Briefing": {
      "title": "Intelligence Briefing",
      "description": "Stores AI-generated intelligence reports",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique ID" },
        "date": { "type": "string", "description": "Formatted date" },
        "region": { "type": "string", "description": "Region code (BR, MX, CO, GLOBAL)" },
        "category": { "type": "string", "enum": ["JOBS", "AI_IMPACT", "RECRUITMENT", "HR", "TECH"], "description": "Content category" },
        "isPremium": { "type": "boolean", "description": "Whether this is premium content" },
        "content": { "type": "object", "description": "Multilingual content" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Generation timestamp" }
      },
      "required": ["id", "date", "region", "category", "isPremium", "content", "createdAt"]
    },
    "Subscription": {
      "title": "Subscription Record",
      "description": "Stores payment and subscription history",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "User UID" },
        "stripeSessionId": { "type": "string", "description": "Stripe Checkout Session ID" },
        "plan": { "type": "string", "description": "Subscription plan name" },
        "amount": { "type": "number", "description": "Payment amount" },
        "currency": { "type": "string", "description": "Payment currency" },
        "status": { "type": "string", "description": "Payment status" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Payment date" }
      },
      "required": ["uid", "stripeSessionId", "plan", "amount", "currency", "status", "createdAt"]
    },
    "MarketNews": {
      "title": "Market News",
      "description": "Stores job market news headlines",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Article title" },
        "description": { "type": "string", "description": "Article description" },
        "url": { "type": "string", "description": "Article URL" },
        "source": { "type": "string", "description": "News source name" },
        "publishedAt": { "type": "string", "format": "date-time", "description": "Publication date" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Last update timestamp" }
      },
      "required": ["title", "url", "source", "publishedAt"]
    },
    "MarketIntelSnapshot": {
      "title": "Market Intelligence Snapshot",
      "description": "Daily snapshot of hiring trends and job volume",
      "type": "object",
      "properties": {
        "date": { "type": "string", "description": "Snapshot date (YYYY-MM-DD)" },
        "trends": { "type": "object", "description": "Hiring trends by sector and company" },
        "volume": { "type": "array", "description": "Job volume by country" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["date", "trends", "volume", "createdAt"]
    },
    "CryptoNews": {
      "title": "Crypto News",
      "description": "Stores cryptocurrency and blockchain news headlines",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Article title" },
        "description": { "type": "string", "description": "Article description" },
        "url": { "type": "string", "description": "Article URL" },
        "source": { "type": "string", "description": "News source name" },
        "publishedAt": { "type": "string", "format": "date-time", "description": "Publication date" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Last update timestamp" }
      },
      "required": ["title", "url", "source", "publishedAt"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "UserProfile",
      "description": "User profiles"
    },
    "/briefings/{id}": {
      "schema": "Briefing",
      "description": "Intelligence briefings"
    },
    "/subscriptions/{id}": {
      "schema": "Subscription",
      "description": "Subscription records"
    },
    "/market_news/{id}": {
      "schema": "MarketNews",
      "description": "Market news articles"
    },
    "/market_intel_snapshots/{date}": {
      "schema": "MarketIntelSnapshot",
      "description": "Daily market intelligence snapshots"
    },
    "/crypto_news/{id}": {
      "schema": "CryptoNews",
      "description": "Cryptocurrency news articles"
    }
  }
}
